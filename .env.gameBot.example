# Chornolis Marches main game bot local env example.
# Copy this file to `.env` for a local game-bot run, then fill real secrets locally.
# Do not commit real tokens, database URLs, admin ids, channel ids or secrets.
#
# This file is for the main Telegram game bot only.
# Herald / Chancery uses `.env.herald.example` and its own HERALD_* variables.

# Required for the main game bot.
# Telegram bot token for the playable Chornolis bot, not the Herald bot.
BOT_TOKEN=

# Required for Prisma and runtime database access.
# Example local shape: postgresql://user:password@localhost:5432/chornolis
DATABASE_URL=

# HTTP status/site server.
# Render provides PORT automatically; local runs default to 3000.
PORT=3000

# Public base URL used in Telegram links and web surfaces.
PUBLIC_BASE_URL=http://localhost:3000

# Optional fallback when package.json cannot be read.
APP_VERSION=dev

# Username of the main game bot, without @.
# Mostly useful for safe public deep links from related services.
GAME_BOT_USERNAME=Chornolis_bot

# Scribe/admin access.
# ADMIN_TELEGRAM_IDS is a comma-separated list of numeric Telegram user ids.
# ADMIN_SET_SECRET powers the hidden /adminSet <secret> bootstrap command.
ADMIN_TELEGRAM_IDS=
ADMIN_SET_SECRET=

# World/action timing.
# WORLD_TICK_INTERVAL_MS is the primary boot-time tick knob. Minimum effective value is 1000.
# TICK_MS is a legacy fallback only used when WORLD_TICK_INTERVAL_MS is absent.
WORLD_TICK_INTERVAL_MS=1500
# TICK_MS=1500

# Session presence.
# Auto-AFK is silent. Auto-end pauses passive hunger for non-auto inactive sessions.
AUTO_AFK_AFTER_MINUTES=13
AUTO_END_SESSION_AFTER_MINUTES=60
AUTO_AFK_CHECK_INTERVAL_MS=60000

# Non-player movement messages.
# Visible spirit/NPC movement is coalesced per location inside this window.
NON_PLAYER_MOVEMENT_NOTIFICATION_WINDOW_MS=60000

# Telegram polling conflict retry for the main game bot.
TELEGRAM_POLLING_CONFLICT_RETRY_MS=15000

# Seed/runtime throughput.
SEED_CONCURRENCY=12
PLAYER_COMPLETION_CONCURRENCY=10
CREATURE_RUNNING_ACTION_BATCH=1000
CREATURE_COMPLETION_CONCURRENCY=25
WORLD_CREATURE_TICK_BUDGET=180

# World resources and natural twigs.
WORLD_RESOURCE_REGEN_EVERY_TICKS=160
WORLD_RESOURCE_REGEN_AMOUNT=1
WORLD_GRASS_REGEN_EVERY_TICKS=120
WORLD_EXHAUSTED_LOCATION_REGEN_EVERY_TICKS=720
WORLD_NATURAL_TWIGS_REGEN_INTERVAL_MS=7200000
WORLD_NATURAL_TWIGS_MAX_AMOUNT=5
WORLD_NATURAL_TWIGS_LOCATION_DIVISOR=3
WORLD_NATURAL_TWIGS_REGION_KEYS=chornolis_border
TREE_SHAKE_COOLDOWN_MS=7200000

# Lisovyk and ambient local speech.
WORLD_LISOVYK_WAKE_DELAY_TICKS=12
HERBALIST_SPEAK_CHANCE=12

# Herbivore reproduction and spread tuning.
WORLD_RABBIT_REPRODUCTION_EVERY_TICKS=120
WORLD_RABBIT_MIN_LITTER_SIZE=5
WORLD_RABBIT_MAX_LITTER_SIZE=10
WORLD_RABBIT_MAX_LITTERS_PER_LOCATION=2
WORLD_RABBIT_LOCAL_SOFT_CAP=6
WORLD_OVERGRAZING_RABBIT_THRESHOLD=5
WORLD_RABBIT_SPREAD_EVERY_TICKS=20
WORLD_RABBIT_MAX_SPREAD_PER_LOCATION=4
WORLD_MOUSE_REPRODUCTION_EVERY_TICKS=20
WORLD_MOUSE_MIN_LITTER_SIZE=5
WORLD_MOUSE_MAX_LITTER_SIZE=10
WORLD_MOUSE_MAX_LITTERS_PER_LOCATION=8
WORLD_MOUSE_LOCAL_SOFT_CAP=8
WORLD_MOUSE_SPREAD_EVERY_TICKS=15
WORLD_MOUSE_MAX_SPREAD_PER_LOCATION=6

# Predator reproduction and prey pressure tuning.
WORLD_FOX_REPRODUCTION_EVERY_TICKS=720
WORLD_FOX_MIN_LITTER_SIZE=2
WORLD_FOX_MAX_LITTER_SIZE=5
WORLD_FOX_PREY_UNITS_REQUIRED_BASE=12
WORLD_FOX_PREY_UNITS_REQUIRED_PER_FOX=6
WORLD_WOLF_REPRODUCTION_EVERY_TICKS=2400
WORLD_WOLF_MIN_LITTER_SIZE=2
WORLD_WOLF_MAX_LITTER_SIZE=4
WORLD_WOLF_PREY_UNITS_REQUIRED_BASE=60
WORLD_WOLF_PREY_UNITS_REQUIRED_PER_WOLF=20

# Crowd danger, panic and starvation tuning.
WORLD_CROWD_DANGER_THRESHOLD=13
WORLD_CROWD_DANGER_INITIAL_BONUS=4
WORLD_CROWD_DANGER_STEP=4
WORLD_CROWD_DANGER_STEP_BONUS=1
WORLD_CROWD_HERBIVORE_MOVE_BASE_CHANCE=12
WORLD_CROWD_HERBIVORE_MOVE_PER_EXTRA_CHANCE=4
WORLD_CROWD_HERBIVORE_MOVE_MAX_CHANCE=55
WORLD_CREATURE_STARVATION_HUNGER_THRESHOLD=20
WORLD_CREATURE_STARVATION_BASE_CHANCE_PERMILLE=80
WORLD_CREATURE_STARVATION_EXTRA_CHANCE_PER_HUNGER_PERMILLE=25
WORLD_RECENT_ATTACK_DANGER_TICKS=20
WORLD_PANIC_HERBIVORE_FLEE_CHANCE=85
WORLD_PANIC_HERBIVORE_MAX_FLEE=18
WORLD_PANIC_HERBIVORE_MOVE_PRIORITY=60

# Observation/learning windows used by current hidden progression helpers.
WORLD_ATTACK_OBSERVATION_WINDOW_MS=120000
WORLD_GATHERING_OBSERVATION_WINDOW_MS=120000
WORLD_FOOD_OBSERVATION_WINDOW_MS=120000

# Player/NPC social autonomy.
PLAYER_AUTO_SAY_CHANCE=15
PLAYER_AUTO_SIGNAL_CHANCE=12
HERBALIST_SIGNAL_CHANCE=18

# Debug flags. Keep false in normal local/prod runs unless investigating.
WORLD_DEBUG=false
WORLD_TICK_DEBUG=false
WORLD_TICK_DEBUG_EVENT=false
STATUS_PERF_DEBUG=false
