{
  "name": "chornolis-marches",
  "version": "0.10.4",
  "description": "Text-based Telegram RPG with a living ecosystem, inspired by MUDs, Ultima Online, and Ukrainian folklore.",
  "main": "dist/bot.js",
  "scripts": {
    "dev": "ts-node-dev src/bot.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/bot.js",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "planning:export": "node scripts/planning/export-planning.mjs",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/q587p/chornolis-marches.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/q587p/chornolis-marches/issues"
  },
  "homepage": "https://github.com/q587p/chornolis-marches#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.42.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2"
  }
