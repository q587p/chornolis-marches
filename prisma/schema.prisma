generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// PLAYER
// =======================

model Player {
  id         Int     @id @default(autoincrement())
  telegramId String  @unique
  username   String?
  firstName  String?
  lastName   String?

  currentLocationId Int?
  currentLocation   CellLocation? @relation(fields: [currentLocationId], references: [id])

  hp           Int @default(20)
  hpMax        Int @default(20)
  stamina      Int @default(42)
  staminaMax   Int @default(42)
  fatigueState FatigueState @default(RESTED)
  posture      PlayerPosture @default(STANDING)
  isResting    Boolean @default(false)
  isAutoEnabled Boolean @default(false)
  showTechnicalDetails Boolean @default(false)
  hunger  Int @default(0)

  // статистика
  steps             Int @default(0)
  looks             Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)
  greetings         Int @default(0)
  animalsKilled     Int @default(0)
  berriesGathered   Int @default(0)
  mushroomsGathered Int @default(0)
  herbsGathered     Int @default(0)
  restStarts        Int @default(0)
  restFullRecoveries Int @default(0)

  lastActionAt DateTime?
  lastStaminaRegenAt DateTime @default(now())
  lastHpRegenAt      DateTime @default(now())

  onboardingComplete Boolean @default(false)
  pronoun            PlayerPronoun?
  nameNominative     String?
  nameGenitive       String?
  nameDative         String?
  nameAccusative     String?
  nameInstrumental   String?
  nameLocative       String?
  nameVocative       String?
  isNameApproved     Boolean @default(false)
  grammaticalGender  GrammaticalGender?
  animacy            Animacy @default(ANIMATE)
  role               PlayerRole @default(PLAYER)

  resources PlayerResource[]
  actions   WorldAction[]
  tracks    WorldTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// WORLD STRUCTURE
// =======================

model Region {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  locations CellLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CellLocation {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  regionId Int
  region   Region @relation(fields: [regionId], references: [id])

  x Int
  y Int
  z Int @default(0)

  biome       BiomeType @default(FOREST)
  dangerLevel Int       @default(1)

  players   Player[]
  creatures Creature[]
  resources ResourceNode[]
  features  LocationFeature[]

  exitsFrom LocationExit[] @relation("ExitFrom")
  exitsTo   LocationExit[] @relation("ExitTo")

  events WorldEvent[]

  tracksFrom WorldTrack[] @relation("TrackFrom")
  tracksTo   WorldTrack[] @relation("TrackTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionId, x, y, z])
}

model LocationExit {
  id Int @id @default(autoincrement())

  fromLocationId Int
  fromLocation   CellLocation @relation("ExitFrom", fields: [fromLocationId], references: [id])

  toLocationId Int
  toLocation   CellLocation @relation("ExitTo", fields: [toLocationId], references: [id])

  direction  Direction
  label      String?
  travelCost Int       @default(1)

  isHidden Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([fromLocationId, direction])
}

model LocationFeature {
  id Int @id @default(autoincrement())

  key String @unique

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  type        LocationFeatureType
  name        String
  description String?

  isActive Boolean @default(true)

  // Used by light/night-visibility and rest systems.
  providesLight Boolean @default(false)

  // Example: 5 means active rest may recover stamina up to staminaMax * 5 in this location.
  restStaminaCapMultiplier Int?

  data Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

// =======================
// CREATURES
// =======================

model CreatureSpecies {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  nameGenitive       String?
  nameDative         String?
  nameAccusative     String?
  nameInstrumental   String?
  nameLocative       String?
  nameVocative       String?
  grammaticalGender  GrammaticalGender @default(MASCULINE)
  animacy            Animacy @default(ANIMATE)

  kind CreatureKind
  diet DietType

  baseHp     Int
  strength   Int
  agility    Int
  perception Int
  endurance  Int
  instinct   Int

  // Lifecycle profile; used for animals only for now.
  childTicks                   Int @default(0)
  youngTicks                   Int @default(24)
  adultTicks                   Int @default(72)
  oldTicks                     Int @default(36)
  oldDeathChancePermille       Int @default(5)
  oldDeathChanceGrowthPermille Int @default(1)
  corpseDecayTicks             Int @default(24)
  mushroomBonusOnDecay         Int @default(2)

  creatures Creature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Creature {
  id Int @id @default(autoincrement())

  speciesId Int
  species   CreatureSpecies @relation(fields: [speciesId], references: [id])

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  name             String?
  nameGenitive     String?
  nameDative       String?
  nameAccusative   String?
  nameInstrumental String?
  nameLocative     String?
  nameVocative     String?

  hp      Int
  maxHp   Int?
  hunger  Int @default(0)
  stamina Int @default(42)
  staminaMax Int @default(42)
  fatigueState FatigueState @default(RESTED)
  lastStaminaRegenAt DateTime @default(now())

  activity      CreatureActivity?
  currentAction String?
  professionKey String?
  professionName String?

  // Lifecycle. Time is stopped for players and named/NPC creatures; animals keep aging.
  age                  CreatureAge @default(ADULT)
  ageTicks             Int @default(0)
  diedAtTick           Int?
  corpseDecayTicksLeft Int?
  isGone               Boolean @default(false)
  isHidden             Boolean @default(false)

  // статистика
  steps             Int @default(0)
  looks             Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)
  attackAttempts    Int @default(0)
  successfulAttacks Int @default(0)
  kills             Int @default(0)

  sex CreatureSex?

  isAlive Boolean @default(true)

  actions WorldAction[]
  tracks  WorldTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// RESOURCES
// =======================

model ResourceType {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  nodes           ResourceNode[]
  playerResources PlayerResource[]
}

model ResourceNode {
  id Int @id @default(autoincrement())

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount    Int @default(0)
  maxAmount Int @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, resourceTypeId])
}

// =======================
// INVENTORY
// =======================

model PlayerResource {
  id Int @id @default(autoincrement())

  playerId Int
  player   Player @relation(fields: [playerId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, resourceTypeId])
}

model CarcassDropoffContribution {
  id Int @id @default(autoincrement())

  dropoffFeatureKey String
  locationId         Int?

  contributorKind String @default("PLAYER")
  playerId        Int?
  creatureId      Int?

  resourceTypeKey String
  amount          Int @default(1)

  createdAt DateTime @default(now())

  @@index([dropoffFeatureKey, contributorKind, playerId])
  @@index([createdAt])
}

// =======================
// ACTION QUEUE
// =======================

model WorldAction {
  id Int @id @default(autoincrement())

  actorType WorldActorType

  playerId Int?
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)

  creatureId Int?
  creature   Creature? @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  type   WorldActionType
  status WorldActionStatus @default(QUEUED)

  priority      Int     @default(0)
  interruptible Boolean @default(true)
  note          String?

  payload Json

  position   Int
  durationMs Int
  startedAt  DateTime?
  executeAt  DateTime?

  chatId    String?
  messageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actorType, playerId, status, position])
  @@index([actorType, creatureId, status, position])
  @@index([actorType, status, executeAt])
  @@index([actorType, status, position, id])
  @@index([status, priority, position])
  @@index([status, executeAt])
}

model WorldTrack {
  id Int @id @default(autoincrement())

  actorType WorldActorType

  playerId Int?
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)

  creatureId Int?
  creature   Creature? @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  fromLocationId Int
  fromLocation   CellLocation @relation("TrackFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)

  toLocationId Int
  toLocation   CellLocation @relation("TrackTo", fields: [toLocationId], references: [id], onDelete: Cascade)

  direction Direction
  label     String
  strength  Int @default(3)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([fromLocationId, expiresAt])
  @@index([toLocationId, expiresAt])
  @@index([actorType, playerId])
  @@index([actorType, creatureId])
}

// =======================
// EVENTS
// =======================

model WorldEvent {
  id Int @id @default(autoincrement())

  type        WorldEventType
  title       String
  description String?

  playerId   Int?
  locationId Int?

  location CellLocation? @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
}

// =======================
// ENUMS
// =======================

enum Direction {
  NORTH
  SOUTH
  EAST
  WEST
  UP
  DOWN
  INSIDE
  OUTSIDE
}

enum BiomeType {
  FOREST
  DEEP_FOREST
  CLEARING
  SWAMP
  RIVER
  HILL
  CAVE
  RUINS
  VILLAGE
}

enum LocationFeatureType {
  BORDER_MARKER
  CAMPFIRE
  MAGIC_CAMPFIRE
  BRIDGE
  GATE
  LANDMARK
}

enum CreatureKind {
  ANIMAL
  HUMAN
  MONSTER
  SPIRIT
}

enum DietType {
  HERBIVORE
  CARNIVORE
  OMNIVORE
  SPIRITUAL
}

enum CreatureSex {
  MALE
  FEMALE
}

enum CreatureAge {
  CHILD
  YOUNG
  ADULT
  OLD
  CORPSE
}

enum CreatureActivity {
  IDLE
  MOVING
  LOOKING
  GATHERING
  RESTING
  SLEEPING
  TALKING
  SPEAKING
  FIGHTING
  SETTING_TRAP
}

enum GrammaticalGender {
  MASCULINE
  FEMININE
  NEUTER
  PLURAL
}

enum Animacy {
  ANIMATE
  INANIMATE
}

enum FatigueState {
  RESTED
  TIRED
  VERY_TIRED
}

enum PlayerPronoun {
  HE
  SHE
  THEY
}

enum PlayerPosture {
  STANDING
  SITTING
}

enum PlayerRole {
  PLAYER
  SCRIBE
}

enum WorldActorType {
  PLAYER
  CREATURE
}

enum WorldActionType {
  MOVE
  GATHER
  GATHER_SPECIFIC
  EAT
  LOOK
  INSPECT
  GREET
  ATTACK
  FRESHEN
  SAY
  TRACK
  REST
  SET_TRAP
  WAIT
}

enum WorldActionStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELLED
}

// 🔥 НЕ ЗВУЖУВАТИ!
enum WorldEventType {
  SYSTEM
  PLAYER_ACTION
  NPC_ACTION
  SOCIAL_SIGNAL
  MOVE
  GATHER
  SAY
  ERROR
  LOOK
  GREET
  INSPECT
  GATHER_ATTEMPT
  GATHER_SUCCESS
  GATHER_FAIL
  NPC_MOVE
  NPC_SAY
}
