generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id         Int     @id @default(autoincrement())
  telegramId String  @unique
  username   String?
  firstName  String?
  lastName   String?

  currentLocationId Int?
  currentLocation   CellLocation? @relation(fields: [currentLocationId], references: [id])

  hp      Int @default(20)
  stamina Int @default(20)
  hunger  Int @default(0)

  steps             Int @default(0)
  looks             Int @default(0)
  greetings         Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)

  lastActionAt DateTime?
  lastSayAt    DateTime?

  inventory PlayerResource[]
  events    WorldEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  locations CellLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CellLocation {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  regionId Int
  region   Region @relation(fields: [regionId], references: [id])

  x Int
  y Int
  z Int @default(0)

  biome       BiomeType @default(FOREST)
  dangerLevel Int       @default(1)

  players   Player[]
  creatures Creature[]
  resources ResourceNode[]
  events    WorldEvent[]

  exitsFrom LocationExit[] @relation("ExitFrom")
  exitsTo   LocationExit[] @relation("ExitTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionId, x, y, z])
}

model LocationExit {
  id Int @id @default(autoincrement())

  fromLocationId Int
  fromLocation   CellLocation @relation("ExitFrom", fields: [fromLocationId], references: [id])

  toLocationId Int
  toLocation   CellLocation @relation("ExitTo", fields: [toLocationId], references: [id])

  direction  Direction
  label      String?
  travelCost Int       @default(1)

  isHidden Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([fromLocationId, direction])
}

enum BiomeType {
  FOREST
  DEEP_FOREST
  CLEARING
  SWAMP
  RIVER
  HILL
  CAVE
  RUINS
  VILLAGE
}

enum Direction {
  NORTH
  SOUTH
  EAST
  WEST
  UP
  DOWN
  INSIDE
  OUTSIDE
}

model CreatureSpecies {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  kind CreatureKind
  diet DietType

  baseHp     Int
  strength   Int
  agility    Int
  perception Int
  endurance  Int
  instinct   Int

  creatures Creature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CreatureKind {
  ANIMAL
  HUMAN
  MONSTER
  SPIRIT
}

enum DietType {
  HERBIVORE
  CARNIVORE
  OMNIVORE
  SPIRITUAL
}

model Creature {
  id Int @id @default(autoincrement())

  speciesId Int
  species   CreatureSpecies @relation(fields: [speciesId], references: [id])

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  name String?

  hp      Int
  hunger  Int @default(0)
  stamina Int @default(20)

  sex CreatureSex?
  age CreatureAge  @default(ADULT)

  activity CreatureActivity @default(IDLE)

  steps             Int @default(0)
  looks             Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)

  isAlive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CreatureSex {
  MALE
  FEMALE
}

enum CreatureAge {
  YOUNG
  ADULT
  OLD
}

enum CreatureActivity {
  IDLE
  LOOKING
  MOVING
  GATHERING
  SPEAKING
  FIGHTING
  SETTING_TRAP
}

model ResourceType {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  nodes             ResourceNode[]
  playerInventories PlayerResource[]
}

model ResourceNode {
  id Int @id @default(autoincrement())

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount    Int @default(0)
  maxAmount Int @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, resourceTypeId])
}

model PlayerResource {
  id Int @id @default(autoincrement())

  playerId Int
  player   Player @relation(fields: [playerId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, resourceTypeId])
}

model WorldEvent {
  id Int @id @default(autoincrement())

  type        WorldEventType
  title       String
  description String?

  locationId Int?
  location   CellLocation? @relation(fields: [locationId], references: [id])

  playerId Int?
  player   Player? @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
}

enum WorldEventType {
  LOOK
  MOVE
  SAY
  GREET
  INSPECT
  GATHER_ATTEMPT
  GATHER_SUCCESS
  GATHER_FAIL
  NPC_MOVE
  NPC_SAY
  SYSTEM
}
