generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// PLAYER
// =======================

model Player {
  id         Int     @id @default(autoincrement())
  telegramId String  @unique
  username   String?
  firstName  String?
  lastName   String?

  currentLocationId Int?
  currentLocation   CellLocation? @relation(fields: [currentLocationId], references: [id])

  hp      Int @default(20)
  stamina Int @default(20)
  hunger  Int @default(0)

  // статистика
  steps             Int @default(0)
  looks             Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)
  greetings         Int @default(0)

  lastActionAt DateTime?

  resources PlayerResource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// WORLD STRUCTURE
// =======================

model Region {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  locations CellLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CellLocation {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  regionId Int
  region   Region @relation(fields: [regionId], references: [id])

  x Int
  y Int
  z Int @default(0)

  biome       BiomeType @default(FOREST)
  dangerLevel Int       @default(1)

  players   Player[]
  creatures Creature[]
  resources ResourceNode[]

  exitsFrom LocationExit[] @relation("ExitFrom")
  exitsTo   LocationExit[] @relation("ExitTo")

  events WorldEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionId, x, y, z])
}

model LocationExit {
  id Int @id @default(autoincrement())

  fromLocationId Int
  fromLocation   CellLocation @relation("ExitFrom", fields: [fromLocationId], references: [id])

  toLocationId Int
  toLocation   CellLocation @relation("ExitTo", fields: [toLocationId], references: [id])

  direction  Direction
  label      String?
  travelCost Int       @default(1)

  isHidden Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([fromLocationId, direction])
}

// =======================
// CREATURES
// =======================

model CreatureSpecies {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  kind CreatureKind
  diet DietType

  baseHp     Int
  strength   Int
  agility    Int
  perception Int
  endurance  Int
  instinct   Int

  // Lifecycle profile; used for animals only for now.
  childTicks                   Int @default(0)
  youngTicks                   Int @default(24)
  adultTicks                   Int @default(72)
  oldTicks                     Int @default(36)
  oldDeathChancePermille       Int @default(5)
  oldDeathChanceGrowthPermille Int @default(1)
  corpseDecayTicks             Int @default(24)
  mushroomBonusOnDecay         Int @default(2)

  creatures Creature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Creature {
  id Int @id @default(autoincrement())

  speciesId Int
  species   CreatureSpecies @relation(fields: [speciesId], references: [id])

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  name String?

  hp      Int
  maxHp   Int?
  hunger  Int @default(0)
  stamina Int @default(20)

  activity      CreatureActivity?
  currentAction String?

  // Lifecycle. Time is stopped for players and named/NPC creatures; animals keep aging.
  age                 CreatureAge @default(ADULT)
  ageTicks            Int @default(0)
  diedAtTick          Int?
  corpseDecayTicksLeft Int?
  isGone              Boolean @default(false)

  // статистика
  steps             Int @default(0)
  looks             Int @default(0)
  says              Int @default(0)
  gatherAttempts    Int @default(0)
  successfulGathers Int @default(0)

  sex CreatureSex?

  isAlive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// RESOURCES
// =======================

model ResourceType {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?

  nodes           ResourceNode[]
  playerResources PlayerResource[]
}

model ResourceNode {
  id Int @id @default(autoincrement())

  locationId Int
  location   CellLocation @relation(fields: [locationId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount    Int @default(0)
  maxAmount Int @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, resourceTypeId])
}

// =======================
// INVENTORY
// =======================

model PlayerResource {
  id Int @id @default(autoincrement())

  playerId Int
  player   Player @relation(fields: [playerId], references: [id])

  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])

  amount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, resourceTypeId])
}

// =======================
// EVENTS
// =======================

model WorldEvent {
  id Int @id @default(autoincrement())

  type        WorldEventType
  title       String
  description String?

  playerId   Int?
  locationId Int?

  location CellLocation? @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
}

// =======================
// ENUMS
// =======================

enum Direction {
  NORTH
  SOUTH
  EAST
  WEST
  UP
  DOWN
  INSIDE
  OUTSIDE
}

enum BiomeType {
  FOREST
  DEEP_FOREST
  CLEARING
  SWAMP
  RIVER
  HILL
  CAVE
  RUINS
  VILLAGE
}

enum CreatureKind {
  ANIMAL
  HUMAN
  MONSTER
  SPIRIT
}

enum DietType {
  HERBIVORE
  CARNIVORE
  OMNIVORE
  SPIRITUAL
}

enum CreatureSex {
  MALE
  FEMALE
}

enum CreatureAge {
  CHILD
  YOUNG
  ADULT
  OLD
  CORPSE
}

enum CreatureActivity {
  IDLE
  MOVING
  LOOKING
  GATHERING
  RESTING
  TALKING
  SPEAKING
  FIGHTING
  SETTING_TRAP
}

// 🔥 НЕ ЗВУЖУВАТИ!
enum WorldEventType {
  SYSTEM
  PLAYER_ACTION
  NPC_ACTION
  MOVE
  GATHER
  SAY
  ERROR
  LOOK
  GREET
  INSPECT
  GATHER_ATTEMPT
  GATHER_SUCCESS
  GATHER_FAIL
  NPC_MOVE
  NPC_SAY
}
